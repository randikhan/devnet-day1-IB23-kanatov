{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "student", "yang", "webex", "pt", "validation_passed"],
  "properties": {
    "schema_version": { "const": "5.0" },
    "student": {
      "type": "object",
      "required": ["token_hash8", "name"],
      "properties": {
        "token_hash8": { "pattern": "^[a-f0-9]{8}$" }
      }
    },
    "yang": {
      "type": "object",
      "required": ["ok", "evidence_sha"]
    },
    "webex": {
      "type": "object",
      "required": ["ok", "room_title_contains_hash8"]
    },
    "pt": {
      "type": "object",
      "required": ["ok", "empty_ticket_seen"]
    },
    "validation_passed": { "type": "boolean" }
  }
}